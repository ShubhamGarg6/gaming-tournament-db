-- Online Gaming Tournament Management System
-- SQL Code
-- =========================

-- Drop existing tables first
DROP TABLE IF EXISTS Score;
DROP TABLE IF EXISTS Match;
DROP TABLE IF EXISTS Player;
DROP TABLE IF EXISTS Tournament;
DROP TABLE IF EXISTS Team;
DROP TABLE IF EXISTS Game;

-- =========================
-- 1. CREATE TABLES
-- =========================

CREATE TABLE Team (
    team_id INTEGER PRIMARY KEY,
    team_name TEXT NOT NULL
);

CREATE TABLE Player (
    player_id INTEGER PRIMARY KEY,
    name TEXT NOT NULL,
    email TEXT NOT NULL,
    team_id INTEGER,
    FOREIGN KEY (team_id) REFERENCES Team(team_id)
);

CREATE TABLE Game (
    game_id INTEGER PRIMARY KEY,
    game_name TEXT NOT NULL
);

CREATE TABLE Tournament (
    tournament_id INTEGER PRIMARY KEY,
    name TEXT NOT NULL,
    game_id INTEGER,
    FOREIGN KEY (game_id) REFERENCES Game(game_id)
);

CREATE TABLE Match (
    match_id INTEGER PRIMARY KEY,
    tournament_id INTEGER,
    team1_id INTEGER,
    team2_id INTEGER,
    match_date TEXT,
    FOREIGN KEY (tournament_id) REFERENCES Tournament(tournament_id),
    FOREIGN KEY (team1_id) REFERENCES Team(team_id),
    FOREIGN KEY (team2_id) REFERENCES Team(team_id)
);

CREATE TABLE Score (
    score_id INTEGER PRIMARY KEY,
    match_id INTEGER,
    team_id INTEGER,
    points INTEGER,
    FOREIGN KEY (match_id) REFERENCES Match(match_id),
    FOREIGN KEY (team_id) REFERENCES Team(team_id)
);

-- =========================
-- 2. INSERT SAMPLE DATA
-- =========================

INSERT INTO Team (team_id, team_name) VALUES
(1, 'Alpha'),
(2, 'Beta'),
(3, 'Gamma');

INSERT INTO Player (player_id, name, email, team_id) VALUES
(1, 'John', 'john@mail.com', 1),
(2, 'Mike', 'mike@mail.com', 2),
(3, 'Alex', 'alex@mail.com', 1),
(4, 'David', 'david@mail.com', 3);

INSERT INTO Game (game_id, game_name) VALUES
(1, 'Valorant'),
(2, 'FIFA 24');

INSERT INTO Tournament (tournament_id, name, game_id) VALUES
(1, 'Winter Cup', 1),
(2, 'Spring Championship', 2);

INSERT INTO Match (match_id, tournament_id, team1_id, team2_id, match_date) VALUES
(1, 1, 1, 2, '2026-03-20'),
(2, 2, 2, 3, '2026-03-25');

INSERT INTO Score (score_id, match_id, team_id, points) VALUES
(1, 1, 1, 13),
(2, 1, 2, 10),
(3, 2, 2, 2),
(4, 2, 3, 1);

-- =========================
-- 3. SELECT QUERIES
-- =========================

SELECT * FROM Team;
SELECT * FROM Player;
SELECT * FROM Game;
SELECT * FROM Tournament;
SELECT * FROM Match;
SELECT * FROM Score;

-- Show players with their team names
SELECT Player.player_id, Player.name, Player.email, Team.team_name
FROM Player
JOIN Team ON Player.team_id = Team.team_id;

-- Show tournament with game name
SELECT Tournament.tournament_id, Tournament.name, Game.game_name
FROM Tournament
JOIN Game ON Tournament.game_id = Game.game_id;

-- Show match details
SELECT Match.match_id, Tournament.name AS tournament_name,
       T1.team_name AS team1, T2.team_name AS team2, Match.match_date
FROM Match
JOIN Tournament ON Match.tournament_id = Tournament.tournament_id
JOIN Team T1 ON Match.team1_id = T1.team_id
JOIN Team T2 ON Match.team2_id = T2.team_id;

-- Show scores with team names
SELECT Score.score_id, Score.match_id, Team.team_name, Score.points
FROM Score
JOIN Team ON Score.team_id = Team.team_id;

-- =========================
-- 4. UPDATE QUERY
-- =========================

UPDATE Player
SET name = 'Alex Updated', email = 'alexupdated@mail.com'
WHERE player_id = 3;

-- =========================
-- 5. DELETE QUERY
-- =========================

DELETE FROM Player
WHERE player_id = 4;</sql><current_tab id="0"/></tab_sql></sqlb_project>
